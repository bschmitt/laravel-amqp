{
  "name": "wangchengtao/laravel-amqp",
  "description": "AMQP wrapper for Laravel to publish and consume messages",
  "keywords": [
    "laravel",
    "rabbitmq"
  ],
  "license": "MIT",
  "support": {
      "issues": "https://github.com/bschmitt/laravel-amqp/issues",
      "source": "https://github.com/bschmitt/laravel-amqp"
  },
  "authors": [
    {
    "name": "Björn Schmitt",
    "email": "code@bjoern.io"
    }
  ],
  "require": {
    "php": "^7.3|^8.0",
    "php-amqplib/php-amqplib": "^3.0"
  },
  "require-dev": {
    "illuminate/config": "^10.0",
    "mockery/mockery": "^1.2",
    "phpoption/phpoption": "1.7.x-dev",
    "phpunit/phpunit": ">=6.0",
    "squizlabs/php_codesniffer": "^3.0@dev",
    "vlucas/phpdotenv": "^5.3",
    "illuminate/support": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Bschmitt\\Amqp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Bschmitt\\Amqp\\Test\\": "test/"
    }
  },
    "extra": {
        "laravel": {
            "providers": [
                "Bschmitt\\Amqp\\Providers\\AmqpServiceProvider"
            ],
            "aliases": {
                "Amqp": "Bschmitt\\Amqp\\Facades\\Amqp"
            }
        }
    },
  "minimum-stability": "dev"
}
